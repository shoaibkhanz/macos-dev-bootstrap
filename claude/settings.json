{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/shoaib/.agents/hooks/session-start.sh",
            "async": false
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node /Users/shoaib/.claude/plugins/cache/cortex/cortex/2.1.1/dist/index.js statusline"
  },
  "enabledPlugins": {
    "plannotator@plannotator": true,
    "context7@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "terraform-skill@antonbabenko": true,
    "linear@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "devops-automation-pack@claude-code-plugins-plus": true,
    "cortex@cortex": true,
    "frontend-design@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "everything-claude-code@everything-claude-code": true
  },
  "extraKnownMarketplaces": {
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    }
  },
  "effortLevel": "high",
  "voiceEnabled": true,
  "mcpServers": {
    "eraser": {
      "command": "npx",
      "args": [
        "@eraserlabs/eraser-mcp"
      ],
      "env": {
        "ERASER_API_TOKEN": "${ERASER_API_TOKEN}",
        "ERASER_API_URL": "https://app.eraser.io/api/mcp"
      }
    }
  }
}
